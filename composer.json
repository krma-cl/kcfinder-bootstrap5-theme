{
  "name": "krma-cl/kcfinder-bootstrap5-theme",
  "description": "Bootstrap 5 theme for KCFinder Resurrected.",
  "type": "library",
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "Krma\\KCFinder\\Bootstrap5Theme\\": "src/"
    }
  },
  "bin": [
    "bin/kcfinder-theme-install"
  ],
  "license": [
    "GPL-3.0-or-later",
    "LGPL-3.0-or-later"
  ],
  "keywords": [
    "bootstrap",
    "file-manager",
    "kcfinder",
    "theme"
  ],
  "homepage": "https://github.com/krma-cl/kcfinder-bootstrap5-theme",
  "support": {
    "issues": "https://github.com/krma-cl/kcfinder-bootstrap5-theme/issues",
    "source": "https://github.com/krma-cl/kcfinder-bootstrap5-theme"
  },
  "suggest": {
    "krma-cl/kcfinder": "KCFinder Resurrected core package.",
    "krma-cl/kcfinder-laravel": "Optional official Laravel integration."
  },
  "archive": {
    "exclude": [
      "/node_modules",
      "/vendor"
    ]
  },
  "scripts": {
    "check": "@php scripts/check-publisher.php"
  }
}
