#!/usr/bin/env php
<?php

declare(strict_types=1);

use Krma\KCFinder\Bootstrap5Theme\ThemePublisher;

$autoload = $GLOBALS['_composer_autoload_path'] ?? dirname(__DIR__) . '/vendor/autoload.php';
require $autoload;

$target = null;
$force = false;
foreach (array_slice($argv, 1) as $argument) {
    if ($argument === '--force') {
        $force = true;
    } elseif (str_starts_with($argument, '--target=')) {
        $target = substr($argument, strlen('--target='));
    }
}

if (!is_string($target) || $target === '') {
    fwrite(STDERR, "Usage: kcfinder-theme-install --target=/path/to/kcfinder/themes [--force]\n");
    exit(2);
}

try {
    $result = (new ThemePublisher())->publish($target, $force);
    fwrite(STDOUT, sprintf(
        "Bootstrap 5 theme %s published to %s (%d files).\n",
        $result['version'],
        $result['path'],
        $result['files']
    ));
} catch (Throwable $exception) {
    fwrite(STDERR, $exception->getMessage() . PHP_EOL);
    exit(1);
}
