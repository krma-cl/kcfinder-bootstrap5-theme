{
  "name": "kcfinder-bootstrap5-theme",
  "version": "0.3.0",
  "private": true,
  "description": "A standalone Bootstrap 5 theme for KCFinder Resurrected",
  "license": "(GPL-3.0-or-later OR LGPL-3.0-or-later)",
  "homepage": "https://github.com/krma-cl/kcfinder-bootstrap5-theme#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krma-cl/kcfinder-bootstrap5-theme.git"
  },
  "bugs": {
    "url": "https://github.com/krma-cl/kcfinder-bootstrap5-theme/issues"
  },
  "keywords": [
    "bootstrap",
    "bootstrap5",
    "ckeditor",
    "file-manager",
    "kcfinder",
    "theme",
    "tinymce"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:css": "sass --no-source-map --style=expanded src/scss/theme.scss dist/bootstrap5/03.bootstrap.css",
    "check": "npm run build && node scripts/check.mjs"
  },
  "devDependencies": {
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "sass": "1.77.8"
  }
}
